# InfoLog Mobile — environment configuration.
# Copy to `.env.local` for development and set real values in your host
# (Vercel/Render/etc.) for production. NEVER commit real secrets.

# --- Database (required) ---
# MongoDB connection string. Use a managed cluster (e.g. MongoDB Atlas) in prod.
MONGODB_URI="mongodb://127.0.0.1:27017/infolog_pwa"

# --- Auth (required) ---
# Strong random secret used to sign session/JWT cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# MUST be set in production — a missing/weak value makes sessions forgeable.
JWT_SECRET="change-me-to-a-long-random-string"

# Access-token session lifetime in minutes (optional, default 15).
SESSION_TIMEOUT_MINUTES="15"

# --- WebAuthn / biometric + TOTP (required in production) ---
# RP ID = your site's registered domain, WITHOUT scheme or port (e.g. app.infolog.com).
# Passkeys are bound to this value, so it must match the deployed domain exactly.
NEXT_PUBLIC_RP_ID="localhost"
# Full origin including scheme (must be HTTPS in production).
NEXT_PUBLIC_ORIGIN="http://localhost:3000"
# Display name shown in the authenticator app / passkey prompt (also the TOTP issuer).
NEXT_PUBLIC_RP_NAME="InfoLog Mobile"
